<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>connectview</title>
  <style>{{.CSS}}</style>
</head>
<body>
  <header class="header">
    <div class="header-left">
      <span class="header-brand">connectview</span>
      <input
        type="text"
        id="filter-input"
        class="header-input"
        placeholder="Filter services / RPCs..."
        autocomplete="off"
      >
    </div>
    <div class="header-right">
      <label class="base-url-label" for="base-url-input">Base URL</label>
      <input
        type="text"
        id="base-url-input"
        class="header-input base-url-input"
        value="http://localhost:8080"
        autocomplete="off"
      >
      <button id="settings-btn" class="icon-btn" title="Settings" aria-label="Settings">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </button>
    </div>
  </header>

  <div class="app-container">
    <aside class="sidebar" id="sidebar"></aside>
    <main class="main" id="main-content">
      <div class="empty-state">
        <p>Select a service or RPC from the sidebar to get started.</p>
      </div>
    </main>
  </div>

  <script>window.__CONNECTVIEW_SERVE_MODE__ = {{.ServeMode}};</script>
  <script>window.__CONNECTVIEW_SCHEMA__ = {{.SchemaJSON}};</script>
  <script>{{.JS}}</script>
</body>
</html>
